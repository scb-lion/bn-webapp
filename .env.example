# Copy to .env.local for `vercel dev`, and set the same vars in the Vercel dashboard for prod.

# MongoDB Atlas connection string (free M0 tier is fine).
# Create at https://www.mongodb.com/cloud/atlas — cluster > Connect > Drivers.
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority"

# Database name to use inside the cluster.
MONGODB_DB="northwind"

# Secret used to sign session JWTs. Use a long random string (e.g. `openssl rand -hex 32`).
# The Edge human-gate (middleware.js) reuses this same secret to sign its captcha
# challenges and "human pass" cookie — no separate secret needed.
JWT_SECRET="change-me-to-a-long-random-secret"

# Optional kill-switch for the bot redirect + slide-to-verify captcha in middleware.js.
# Set to "1" on a deployment to disable the gate entirely (e.g. to run E2E against a
# preview URL). Leave unset in production. Local `dev-server.js` never runs middleware,
# so localhost is already gate-free without this.
# GATE_DISABLED="1"

# Initial admin, created by `npm run seed` (only used by the seed script).
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Bank Admin"
